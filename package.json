{
  "name": "tagaa",
  "version": "0.1.0",
  "description": "Terminal Autonomous Group AI Assistant - Multi-model autonomous group chat assistant",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tagaa": "./tui/tagaa-tui.exe"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "build:tui": "cd tui && go build -ldflags=\"-s -w\" -o tagaa-tui.exe .",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@google/genai": "^1.0.0",
    "@inquirer/prompts": "^5.0.0",
    "@mistralai/mistralai": "^1.0.0",
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "diff": "^5.2.0",
    "ink": "^4.4.0",
    "openai": "^4.55.0",
    "ora": "^8.0.0",
    "react": "^18.2.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/diff": "^5.2.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "tsup": "^8.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}